# API target: local | test | production
VITE_ENV=local

# Optional: override local API URL (default http://127.0.0.1:3800)
# VITE_API_URL=http://127.0.0.1:3902

# Vercel: set VITE_ENV in Project → Settings → Environment Variables, then redeploy.
#   Production (holisticare.vercel.app)     → VITE_ENV=production
#   Preview/Staging (holisticare-develop...)  → VITE_ENV=test
# Do not use VITE_ENV=local on Vercel deployments.
